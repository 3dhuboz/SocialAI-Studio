rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A user can only read/write their own top-level doc and all subcollections
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // posts subcollection
      match /posts/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // agency client workspaces
      match /clients/{clientId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // client posts subcollection
        match /posts/{postId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
