# ── Clerk (Authentication) ──
# Get from https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_

# ── AI Worker (Cloudflare Worker — OpenRouter proxy + D1 database) ──
# Local dev: http://localhost:8787
# Production: https://socialai-api.steve-700.workers.dev
VITE_AI_WORKER_URL=https://socialai-api.steve-700.workers.dev

# ── Stripe ──
VITE_STRIPE_PUBLISHABLE_KEY=

# ── EmailJS ──
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ── Facebook OAuth ──
VITE_FACEBOOK_APP_ID=
# Facebook Login for Business — Configuration ID (developers.facebook.com → your app
# → Facebook Login for Business → Configurations → copy the ID).
# When set, the Connect button uses the modern asset-picker dialog (one click).
# When empty, falls back to the legacy scope-checkbox dialog.
VITE_FACEBOOK_LOGIN_CONFIG_ID=

# ── Google Maps ──
VITE_GOOGLE_MAPS_API_KEY=
