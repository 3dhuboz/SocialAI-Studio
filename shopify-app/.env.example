# Copy to .env (or .env.local) before running `npm run dev` / `npm run build`.
# Both vars are required.

# Your Shopify app's Client ID, from Partners dashboard → Apps → Configuration.
# Same value as `client_id` in /shopify.app.toml AND the worker's
# SHOPIFY_API_KEY secret. PUBLIC — embedded in the built HTML.
VITE_SHOPIFY_API_KEY=

# The worker base URL. Defaults to the production worker if unset.
# Override for staging or local dev.
VITE_API_BASE_URL=https://socialai-api.steve-700.workers.dev
