# Cloudflare Pages headers. Applied to all *.pages.dev + custom-domain
# variants of every SocialAI Studio Pages project (socialaistudio.au,
# social.hugheseysque.au, social.picklenick.au, â€¦).
#
# frame-ancestors â€” keep in sync with white-label client roots in
# src/client.configs/. Each customer's main website embeds their own
# social.* subdomain in /admin â†’ Social & AI tab via iframe. Without the
# parent domain in this list, the browser refuses to render the iframe
# (CSP violation, gray box / broken-doc icon).
#
# PennyBuilder entries embed socialaistudio.au itself from the PB Builder.
# Customer-root entries embed the matching social.* subdomain.
#
# Long-term: generate this from src/client.configs/* at build time so
# adding a new white-label client doesn't drop the CSP step.
/*
  Content-Security-Policy: frame-ancestors 'self' https://builder.pennywiseit.com.au https://*.pennywiseit.com.au https://pennybuilder.steve-700.workers.dev https://hugheseysque.au https://www.hugheseysque.au https://picklenick.au https://www.picklenick.au https://streetmeatzbbq.com.au https://www.streetmeatzbbq.com.au https://gladstonebbqfestival.com.au https://www.gladstonebbqfestival.com.au https://jenniannesjewels.com.au https://www.jenniannesjewels.com.au https://jonesysgarage.com.au https://www.jonesysgarage.com.au https://issolutions.com.au https://www.issolutions.com.au
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Service worker â€” never cache the SW file itself or browsers will keep
# serving the old one for hours after a deploy. Cache headers on the
# script body, scope override for the SW, and a short TTL all help.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Manifest â€” short cache so updates roll out fast, but cacheable for the
# page-load duration. Explicit content-type because some hosts default
# .webmanifest to text/plain which Chrome will reject.
/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=300

# SEO files â€” served at the domain root so search engines can discover them.
# Short cache so updates (new sitemap entries, robots policy tweaks) roll out
# inside an hour.
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
